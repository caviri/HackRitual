# =============================================================================
# HackRitual — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# ------------------------------------------------------------------ #
# Application
# ------------------------------------------------------------------ #
# Public URL of this instance (used in CORS, links, etc.)
APP_BASE_URL=http://localhost:7860

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------------ #
# Storage
# ------------------------------------------------------------------ #
# Path to the SQLite database file
DB_PATH=/data/app.db

# Directory for uploaded files. Served publicly at /uploads — must NOT
# contain the database file (startup refuses that configuration).
UPLOAD_DIR=/data/uploads

# ------------------------------------------------------------------ #
# Authentication
# ------------------------------------------------------------------ #
# Secret key for signing JWTs — must be stable across restarts!
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_here

# ------------------------------------------------------------------ #
# Admin seeding (both required)
# ------------------------------------------------------------------ #
# Comma-separated list of email addresses that hold the admin role.
# The FIRST address is the primary admin: its access password is re-synced
# to ADMIN_PASSWORD on every startup (also the lockout recovery path).
ADMIN_SEED_EMAILS=admin@example.com

# Login password for the primary admin (min 8 characters)
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ------------------------------------------------------------------ #
# Event metadata (optional — all have placeholder defaults)
# These seed the event record on FIRST boot only; afterwards the admin
# panel ("event identity" card) owns the title and dates.
# ------------------------------------------------------------------ #
# EVENT_ID=hackritual-2026-example
# EVENT_TITLE=HackRitual Example Event
# EVENT_TYPE=hackathon
# ISO 8601 datetimes
# EVENT_START=2026-03-01T09:00:00+01:00
# EVENT_END=2026-03-02T17:00:00+01:00

# ------------------------------------------------------------------ #
# Operational toggles (optional)
# ------------------------------------------------------------------ #
# Advance DRAFT→OPEN at EVENT_START and OPEN→FROZEN at EVENT_END automatically
AUTO_TRANSITIONS=false
# Run the in-process task queue worker (scoring/export/push)
ENABLE_WORKER=true
# Apply the IP/abuse rate-limit middleware (adds X-RateLimit-* headers)
ENABLE_RATE_LIMIT=true
# Serve each event stage from its own writable SQLite snapshot
# (<data>/demo/<stage>.db); visitors pick a stage via the demo bar.
DEMO_STAGES=false

# ------------------------------------------------------------------ #
# WASM scoring (optional — MVP-3)
# ------------------------------------------------------------------ #
WASM_TIME_LIMIT_MS=5000
WASM_MEMORY_LIMIT_MB=64

# ------------------------------------------------------------------ #
# GitHub export (optional — MVP-4)
# ------------------------------------------------------------------ #
# GITHUB_EXPORT_REPO=owner/repo
# GITHUB_TOKEN=ghp_...
# GITHUB_EXPORT_BRANCH=gh-pages
