# =============================================================================
# HackRitual — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# ------------------------------------------------------------------ #
# Application
# ------------------------------------------------------------------ #
# Public URL of this instance (used in CORS, links, etc.)
APP_BASE_URL=http://localhost:7860

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------------ #
# Storage
# ------------------------------------------------------------------ #
# Path to the SQLite database file
DB_PATH=/data/app.db

# Directory for uploaded files
UPLOAD_DIR=/data/uploads

# ------------------------------------------------------------------ #
# Authentication
# ------------------------------------------------------------------ #
# Secret key for signing JWTs — must be stable across restarts!
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_here

# ------------------------------------------------------------------ #
# Admin seeding (at least one required)
# ------------------------------------------------------------------ #
# Comma-separated list of email addresses that get admin role on first login
ADMIN_SEED_EMAILS=admin@example.com

# One-time token for claiming admin via /api/admin/setup (optional)
# ADMIN_SETUP_TOKEN=

# ------------------------------------------------------------------ #
# Event metadata
# ------------------------------------------------------------------ #
EVENT_ID=hackritual-2026-example
EVENT_TITLE=HackRitual Example Event
EVENT_TYPE=hackathon
# ISO 8601 datetimes
EVENT_START=2026-03-01T09:00:00+01:00
EVENT_END=2026-03-02T17:00:00+01:00

# ------------------------------------------------------------------ #
# Operational toggles (optional)
# ------------------------------------------------------------------ #
# Advance DRAFT→OPEN at EVENT_START and OPEN→FROZEN at EVENT_END automatically
AUTO_TRANSITIONS=false
# Run the in-process task queue worker (scoring/export/push)
ENABLE_WORKER=true
# Apply the IP/abuse rate-limit middleware (adds X-RateLimit-* headers)
ENABLE_RATE_LIMIT=true

# ------------------------------------------------------------------ #
# WASM scoring (optional — MVP-3)
# ------------------------------------------------------------------ #
WASM_TIME_LIMIT_MS=5000
WASM_MEMORY_LIMIT_MB=64

# ------------------------------------------------------------------ #
# GitHub export (optional — MVP-4)
# ------------------------------------------------------------------ #
# GITHUB_EXPORT_REPO=owner/repo
# GITHUB_TOKEN=ghp_...
# GITHUB_EXPORT_BRANCH=gh-pages
