{
    "name": "hackritual-dev",
    "build": {
      "dockerfile": "Dockerfile"
    },
    "runArgs": [
      "-p", "2222:22",
      "-p", "8888:8888"
    ],
    "mounts": [
      "source=${localWorkspaceFolder}/.devcontainer/persist/config,target=/home/vscode/.config,type=bind",
      "source=${localWorkspaceFolder}/.devcontainer/persist/local-share,target=/home/vscode/.local/share,type=bind",
      "source=${localWorkspaceFolder}/.devcontainer/persist/cache,target=/home/vscode/.cache,type=bind",
      "source=${localWorkspaceFolder}/data,target=/persist/pi-coding-agent,type=bind,target=/home/vscode/.pi,type=bind"
    ],
    "remoteUser": "vscode",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "customizations": {
      "vscode": {
        "settings": {
          "python.defaultInterpreterPath": "/usr/bin/python3",
          "python.envFile": "${workspaceFolder}/.env"
        },
        "extensions": [
          "ms-python.python",
          "ms-python.vscode-pylance"
        ]
      }
    },
  
    // Start Python HTTP server in the background on port 8000
    "postCreateCommand": "python3 -m http.server 8000 &",
    
    // Start server when attaching to container (if not already running)
    "postAttachCommand": "ss -lnt | grep -q ':8000 ' || python3 -m http.server 8000 &",
    "postStartCommand": "sudo mkdir -p /run/sshd && sudo /usr/sbin/sshd"
  }