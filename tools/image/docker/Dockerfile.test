# Dev/test image — backend only, uses uv. Mounts the repo and runs pytest
# against a fresh SQLite during schema work. No frontend stage.

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Pull uv from its official image — no curl, no compile, no pip-bootstrap.
COPY --from=ghcr.io/astral-sh/uv:0.5.4 /uv /uvx /usr/local/bin/

WORKDIR /app

# Runtime + test deps installed into the system env. We avoid `uv sync` here
# because the source is bind-mounted at run time, not built into the image.
COPY backend/requirements.txt /app/requirements.txt
RUN uv pip install --system --no-cache -r /app/requirements.txt \
 && uv pip install --system --no-cache \
        pytest==8.3.4 \
        pytest-asyncio==0.24.0 \
        httpx==0.28.1 \
        anyio==4.7.0

# Source is mounted as a volume at /app/backend (or the repo at /app).
WORKDIR /app/backend

CMD ["pytest", "-v"]
